{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"title": "Numbered",
	"slug": "numbered-content",
	"blockTypes": [ "core/group" ],
	"styles": {
		"blocks": {
			"core/heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading, var(--wp--preset--font-family--system-font))",
					"fontSize": "var(--wp--preset--font-size--large, 1.5rem)",
					"fontWeight": "600"
				},
				"spacing": {
					"margin": {
						"bottom": "var(--wp--preset--spacing--small, 0.75rem)"
					}
				}
			}
		},
		"border": {
			"color": "var(--wp--preset--color--contrast-2, #ddd)",
			"radius": "8px",
			"style": "solid",
			"width": "1px"
		},
		"spacing": {
			"padding": {
				"top": "var(--wp--preset--spacing--medium, 1.5rem)",
				"right": "var(--wp--preset--spacing--medium, 1.5rem)",
				"bottom": "var(--wp--preset--spacing--medium, 1.5rem)",
				"left": "var(--wp--preset--spacing--medium, 1.5rem)"
			}
		},
		"shadow": "var(--wp--preset--shadow--natural, 0 2px 4px rgba(0, 0, 0, 0.1))"
	}
}

